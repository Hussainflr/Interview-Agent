LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LOCAL_LLM_TEMPERATURE=0.4
LOCAL_LLM_MAX_TOKENS=900
LOCAL_LLM_TIMEOUT_SECONDS=60
LOCAL_LLM_RETRIES=1
PRIVACY_MODE=local_only
ENABLE_TTS=false
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Required by integrated LobeChat. setup.sh/run.sh generate stable local values in .env.
KEY_VAULTS_SECRET=
AUTH_SECRET=
DATABASE_DRIVER=node
DATABASE_URL=
LOBE_DB_NAME=lobechat
LOBE_POSTGRES_PORT=54322
POSTGRES_PASSWORD=interview-local-postgres

# Optional cloud providers. Leave empty for fully local/offline use.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
XAI_API_KEY=
XAI_MODEL=grok-2-latest
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8001/v1
OPENAI_COMPATIBLE_MODEL=local-model
